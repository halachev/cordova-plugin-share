<plugin id="com.softmex.share" version="1.0.0"
        xmlns="http://apache.org/cordova/ns/plugins"
        xmlns:android="http://schemas.android.com/apk/res/android">
    <name>SharePlugin</name>

    <js-module src="www/share.js" name="SharePlugin">
        <clobbers target="cordova.plugins.sharePlugin" />
    </js-module>

    <platform name="ios">
        <source-file src="src/ios/SharePlugin.m" />
        <header-file src="src/ios/SharePlugin.h" />
    </platform>
</plugin>
